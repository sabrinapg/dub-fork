# ============================================================
# dub — .gitignore
# ============================================================

# --- Secrets / environment ---
.env
.env.local
.env.*.local
*.env

# NOTE: js/config.js holds your Supabase URL + anon key.
# The anon key is safe to expose publicly (it's designed for
# client-side use), so config.js is fine to commit. If you ever
# add a *service role* key or other secret, keep it out of the
# repo and load it only in server-side code (e.g. a Vercel
# serverless function's environment variables).

# --- OS files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Node (in case you add tooling later: Vite, build scripts, etc.) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Vercel ---
.vercel

# --- Build output (if you later add a bundler) ---
dist/
build/
.cache/

# --- Logs ---
*.log
logs/

# --- Local scratch / temp files ---
*.tmp
*.bak
tmp/
